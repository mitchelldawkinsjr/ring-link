###############################################################################
# RingLink — production env (VPS / Docker Compose)
#
# Copy this file to `.env` in the same directory as docker-compose.prod.yml
# on the VPS, then fill in the values.
#
# This single file feeds both:
#   - compose CLI variable interpolation (${MYSQL_PASSWORD}, …)
#   - each service's env_file: directive (vars injected into containers)
#
# Generate APP_KEY once on the server with:
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
#
###############################################################################

# --- Core ---------------------------------------------------------------------
APP_NAME=RingLink
APP_ENV=production
APP_KEY=                                # base64:... (php artisan key:generate)
APP_DEBUG=false
# Public URL of the API (Laravel). Served via NPM → ringlink-nginx:80.
APP_URL=https://api.ringlink.360web.cloud
# Public URL of the Next.js frontend. Served via NPM → ringlink-frontend:3000.
FRONTEND_URL=https://ringlink.360web.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# --- Logging ------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- CORS / Sanctum -----------------------------------------------------------
# Comma-separated list of public domains that can call this API.
CORS_ALLOWED_ORIGINS=https://ringlink.360web.cloud,https://api.ringlink.360web.cloud,https://ringlink.app,https://www.ringlink.app
SANCTUM_STATEFUL_DOMAINS=ringlink.360web.cloud,api.ringlink.360web.cloud,ringlink.app,www.ringlink.app

# --- Database (containerized MySQL) ------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ringlink
DB_USERNAME=ringlink
DB_PASSWORD=                            # set + mirror to MYSQL_PASSWORD below
MYSQL_DATABASE=ringlink
MYSQL_USER=ringlink
MYSQL_PASSWORD=                         # same value as DB_PASSWORD
MYSQL_ROOT_PASSWORD=                    # strong random string

# --- Cache / Queue / Session --------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Redis (containerized) ----------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Mail ---------------------------------------------------------------------
# Replace with your transactional provider (Postmark, Resend, SES, etc.).
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@ringlink.app"
MAIL_FROM_NAME="RingLink"
MAIL_SCHEME=tls

# --- Cloudflare R2 (S3-compatible) for wrestler media ------------------------
RINGLINK_UPLOAD_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET=ringlink-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.ringlink.app
R2_USE_PATH_STYLE_ENDPOINT=true

# --- Sentry (optional, recommended) -------------------------------------------
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- PWA / Vite ---------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# --- Frontend (Next.js, build-time) -------------------------------------------
# Baked into the static JS bundle at `docker compose build frontend`.
# Must point at the API's public URL.
NEXT_PUBLIC_API_URL=https://api.ringlink.360web.cloud/api/v1
